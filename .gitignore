# Swift / SPM
.build/
.swiftpm/
# Package.resolved is intentionally tracked — this is an executable,
# not a library, so we want a reproducible lockfile in the repo.
*.xcodeproj/
DerivedData/
*.hmap
*.ipa
*.xcuserstate

# macOS
.DS_Store
*.swp
*~.nib

# Editor / IDE
.vscode/
.idea/

# Logs / runtime artefacts
*.log
/tmp/
/coverage/

# Bundle output
/dist/

# Generated app icon (rebuilt from docs/logo.png by scripts/make-icon.sh
# and lazily by scripts/bundle.sh)
/Resources/AppIcon.icns

# Local environment
.env
.env.local
